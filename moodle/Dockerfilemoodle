FROM php:8.2-apache

RUN apt-get update && apt-get install -y \
    git unzip libpng-dev libjpeg-dev libfreetype6-dev \
    libzip-dev libicu-dev libxml2-dev mariadb-client \
    && docker-php-ext-configure gd --with-freetype --with-jpeg \
    && docker-php-ext-install \
        gd intl mysqli pdo pdo_mysql zip opcache soap exif \
    && a2enmod rewrite headers

# Clone Moodle
RUN git clone -b MOODLE_501_STABLE git://git.moodle.org/moodle.git /var/www/moodle

# Required for Moodle 5.1+
RUN sed -i 's|/var/www/html|/var/www/moodle/public|g' /etc/apache2/sites-available/000-default.conf

RUN chown -R www-data:www-data /var/www/moodle

WORKDIR /var/www/moodle

EXPOSE 80