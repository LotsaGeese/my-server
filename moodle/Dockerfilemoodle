FROM php:8.2-apache

# 1. Install system dependencies and PHP extensions required by Moodle
RUN apt-get update && apt-get install -y \
    git \
    unzip \
    libpng-dev \
    libjpeg-dev \
    libfreetype6-dev \
    libzip-dev \
    libicu-dev \
    libxml2-dev \
    mariadb-client \
    sudo \
    && docker-php-ext-configure gd --with-freetype --with-jpeg \
    && docker-php-ext-install gd intl mysqli pdo pdo_mysql zip opcache soap exif \
    && a2enmod rewrite headers

# 2. Fix the "Parent directory not writeable" & PHP security restrictions
# We explicitly allow PHP to access the moodledata folder via open_basedir
RUN { \
    echo 'open_basedir = /var/www/moodle:/var/moodledata:/tmp:/bin:/usr/bin'; \
    echo 'upload_max_filesize = 100M'; \
    echo 'post_max_size = 100M'; \
    echo 'memory_limit = 512M'; \
    echo 'max_execution_time = 300'; \
    echo 'opcache.enable = 1'; \
    echo 'opcache.memory_consumption = 128'; \
    echo 'opcache.max_accelerated_files = 10000'; \
} > /usr/local/etc/php/conf.d/moodle-custom.ini

# 3. Configure Apache to point to Moodle and suppress domain warnings
ENV APACHE_DOCUMENT_ROOT /var/www/moodle
RUN sed -ri -e 's!/var/www/html!${APACHE_DOCUMENT_ROOT}!g' /etc/apache2/sites-available/*.conf
RUN sed -ri -e 's!/var/www/!${APACHE_DOCUMENT_ROOT}!g' /etc/apache2/apache2.conf /etc/apache2/conf-available/*.conf
RUN echo "ServerName moodle.hippity.internal" >> /etc/apache2/apache2.conf

# 4. Clone Moodle code
RUN git clone -